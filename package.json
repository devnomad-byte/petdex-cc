{
  "name": "petdex-cc",
  "version": "0.1.13",
  "description": "Desktop pet companion for Claude Code — animated pets from Petdex that react to your coding in real-time",
  "main": "dist/src/main/index.js",
  "type": "module",
  "bin": {
    "petdex-cc": "./dist/bin/cli.js"
  },
  "scripts": {
    "dev": "tsx src/main/index.ts",
    "dev:renderer": "electron .",
    "preinstall": "node dist/src/cli/preinstall.js",
    "postinstall": "node dist/src/cli/postinstall.js",
    "build": "tsc && node build-copy.mjs && npx esbuild src/renderer/renderer.ts --bundle --outfile=dist/src/renderer/renderer.js --format=iife --platform=node --external:electron --external:@electron/remote --allow-overwrite",
    "start": "node dist/bin/cli.js start",
    "prepublishOnly": "npm run build",
    "check": "tsc --noEmit"
  },
  "keywords": [
    "claude-code",
    "petdex",
    "desktop-pet",
    "electron",
    "hooks",
    "ai-pet",
    "virtual-pet",
    "coding-companion",
    "developer-tools",
    "tamagotchi",
    "desktop-mascot",
    "screen-pet",
    "claude",
    "ai-assistant",
    "cli-tools"
  ],
  "license": "MIT",
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "auto-launch": "^5.0.6",
    "electron": "^35.0.0",
    "node-machine-id": "^1.1.12"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "src/assets/",
    "src/hooks/bridge.ps1",
    "src/hooks/bridge.sh",
    "README.md",
    "README_CN.md",
    "LICENSE"
  ]
}
